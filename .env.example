# Cloudflare Pages (production build — set in Pages Dashboard too)
# VITE_MONSTER_API_URL=https://your-tunnel.trycloudflare.com
# MONSTER_TUNNEL_URL=https://your-tunnel.trycloudflare.com

# Dify workflow orchestration (optional — parallel to Monster native)
# DIFY_API_KEY=app-xxxxxxxx

# Sentry error monitoring (optional)
# SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000
# VITE_SENTRY_DSN=https://xxx@o000.ingest.sentry.io/000

# Jam bug recording (optional — Web UI)
# VITE_JAM_TEAM_ID=your-jam-team-id

# Make.com webhook secret (optional)
# MAKE_WEBHOOK_SECRET=your-random-secret

# GitHub Actions deploy (secrets, not in .env):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Node API (tRPC)
NODE_ENV=development
JWT_SECRET=dev-secret-change-me
VITE_APP_ID=monster-ai-local
PYTHON_API_URL=http://127.0.0.1:7860
PORT=3000

# Local JSON persistence when DATABASE_URL is unset (default: .monster-data/)
# MONSTER_DATA_DIR=.monster-data

# Optional OAuth (omit in local dev — use guest mode or /api/oauth/dev-login)
# OAUTH_SERVER_URL=https://your-oauth-server
# VITE_OAUTH_PORTAL_URL=https://your-oauth-portal

# Optional MySQL (omit to use in-memory + Python bridge)
# DATABASE_URL=mysql://user:pass@127.0.0.1:3306/monsterai